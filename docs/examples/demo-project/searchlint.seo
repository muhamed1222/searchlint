language 1

site "https://example.com"

policy productPage {
  indexable true
  canonical self
  title {
    required true
  }
  description {
    required true
  }
  schema Product
}

route "/" {
  indexable true
  canonical self
  title {
    required true
  }
  description {
    required true
  }
}

route "/products/[slug]" {
  use productPage
}

route "/admin/**" {
  indexable false
}
