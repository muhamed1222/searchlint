{
  "name": "@searchlint/next",
  "version": "1.0.0-beta.13",
  "description": "SearchLint Next.js development integration",
  "license": "Apache-2.0",
  "sideEffects": false,
  "type": "module",
  "files": [
    "dist/src",
    "RULE_CATALOG.yaml",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./dev-client": {
      "types": "./dist/src/dev-client.d.ts",
      "import": "./dist/src/dev-client.js",
      "default": "./dist/src/dev-client.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@searchlint/browser": "workspace:*",
    "@searchlint/core": "workspace:*",
    "@searchlint/language": "workspace:*",
    "@searchlint/overlay": "workspace:*"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0 <12.0.0"
  },
  "keywords": [
    "searchlint",
    "seo",
    "technical-seo",
    "nextjs",
    "diagnostics"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "searchlint": {
    "layer": "analyzer",
    "copyAssets": [
      {
        "source": "../../specs/RULE_CATALOG.yaml",
        "target": "RULE_CATALOG.yaml"
      }
    ],
    "generatedTextModules": [
      {
        "source": "../../specs/RULE_CATALOG.yaml",
        "target": "src/catalog.generated.ts",
        "exportName": "bundledRuleCatalogText"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/muhamed1222/searchlint",
    "directory": "packages/next"
  },
  "homepage": "https://github.com/muhamed1222/searchlint#readme",
  "bugs": {
    "url": "https://github.com/muhamed1222/searchlint/issues"
  }
}
