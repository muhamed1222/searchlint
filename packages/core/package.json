{
  "name": "@searchlint/core",
  "version": "1.0.0-beta.3",
  "description": "SearchLint deterministic SEO rule engine",
  "license": "Apache-2.0",
  "sideEffects": false,
  "type": "module",
  "files": [
    "dist/src",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0 <12.0.0"
  },
  "keywords": [
    "searchlint",
    "seo",
    "technical-seo",
    "nextjs",
    "diagnostics"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "searchlint": {
    "layer": "core",
    "ownsRuleEngine": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/muhamed1222/searchlint",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/muhamed1222/searchlint#readme",
  "bugs": {
    "url": "https://github.com/muhamed1222/searchlint/issues"
  }
}
