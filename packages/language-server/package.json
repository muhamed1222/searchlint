{
  "name": "searchlint-language-server",
  "version": "1.0.0-beta.1",
  "description": "SearchLint language server",
  "license": "Apache-2.0",
  "sideEffects": false,
  "type": "module",
  "files": [
    "dist/src",
    "package.json"
  ],
  "bin": {
    "searchlint-language-server": "./dist/src/node.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/server.d.ts",
      "import": "./dist/src/server.js"
    },
    "./node": {
      "types": "./dist/src/node.d.ts",
      "import": "./dist/src/node.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@searchlint/lsp": "workspace:*",
    "vscode-languageserver": "10.0.0",
    "vscode-languageserver-textdocument": "1.0.12"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "searchlint",
    "seo",
    "technical-seo",
    "nextjs",
    "diagnostics",
    "lsp"
  ],
  "publishConfig": {
    "provenance": true
  },
  "searchlint": {
    "layer": "interface"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/muhamed1222/searchlint",
    "directory": "packages/language-server"
  },
  "homepage": "https://github.com/muhamed1222/searchlint#readme",
  "bugs": {
    "url": "https://github.com/muhamed1222/searchlint/issues"
  }
}
