{
  "name": "searchlint",
  "version": "1.0.0-beta.23",
  "description": "SearchLint CLI wrapper for the local developer SEO diagnostics tool",
  "license": "Apache-2.0",
  "sideEffects": false,
  "type": "module",
  "files": [
    "dist/src",
    "package.json"
  ],
  "bin": {
    "searchlint": "./dist/src/bin.js"
  },
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@searchlint/cli": "workspace:*"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0 <12.0.0"
  },
  "keywords": [
    "searchlint",
    "seo",
    "technical-seo",
    "nextjs",
    "diagnostics",
    "cli"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "searchlint": {
    "layer": "interface",
    "wrapperFor": "@searchlint/cli"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/muhamed1222/searchlint",
    "directory": "packages/searchlint"
  },
  "homepage": "https://github.com/muhamed1222/searchlint#readme",
  "bugs": {
    "url": "https://github.com/muhamed1222/searchlint/issues"
  }
}
