{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "SearchLint Cloud secret vault: customer-managed KMS key and Secrets Manager slots for service secrets.",
  "Parameters": {
    "EnvironmentName": {
      "Type": "String",
      "Default": "prod",
      "AllowedPattern": "^[a-z0-9-]+$"
    }
  },
  "Resources": {
    "SearchLintSecretsKey": {
      "Type": "AWS::KMS::Key",
      "Properties": {
        "Description": "SearchLint Cloud KMS key for service secrets and future OAuth token envelope encryption.",
        "EnableKeyRotation": true,
        "KeyPolicy": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Sid": "EnableIamUserPermissions",
              "Effect": "Allow",
              "Principal": {
                "AWS": {
                  "Fn::Sub": "arn:${AWS::Partition}:iam::${AWS::AccountId}:root"
                }
              },
              "Action": "kms:*",
              "Resource": "*"
            }
          ]
        }
      }
    },
    "SearchLintSecretsKeyAlias": {
      "Type": "AWS::KMS::Alias",
      "Properties": {
        "AliasName": {
          "Fn::Sub": "alias/searchlint/${EnvironmentName}/secrets"
        },
        "TargetKeyId": {
          "Ref": "SearchLintSecretsKey"
        }
      }
    },
    "StripeWebhookSecret": {
      "Type": "AWS::SecretsManager::Secret",
      "Properties": {
        "Name": {
          "Fn::Sub": "searchlint/${EnvironmentName}/stripe/webhook-secret"
        },
        "Description": "SearchLint Cloud SEARCHLINT_STRIPE_WEBHOOK_SECRET. Replace generated placeholder before production webhook deployment.",
        "KmsKeyId": {
          "Fn::GetAtt": ["SearchLintSecretsKey", "Arn"]
        },
        "GenerateSecretString": {
          "PasswordLength": 48,
          "ExcludeCharacters": "\"'\\",
          "RequireEachIncludedType": true
        }
      }
    },
    "OtelHeadersSecret": {
      "Type": "AWS::SecretsManager::Secret",
      "Properties": {
        "Name": {
          "Fn::Sub": "searchlint/${EnvironmentName}/otel/exporter-headers"
        },
        "Description": "SearchLint Cloud OTEL_EXPORTER_OTLP_HEADERS secret-bearing exporter headers. Replace generated placeholder before production exporter deployment.",
        "KmsKeyId": {
          "Fn::GetAtt": ["SearchLintSecretsKey", "Arn"]
        },
        "GenerateSecretString": {
          "PasswordLength": 64,
          "ExcludeCharacters": "\"'\\",
          "RequireEachIncludedType": true
        }
      }
    }
  },
  "Outputs": {
    "SearchLintSecretsKeyArn": {
      "Description": "Use this ARN as KmsKeyArn for SearchLint AWS templates.",
      "Value": {
        "Fn::GetAtt": ["SearchLintSecretsKey", "Arn"]
      }
    },
    "SearchLintSecretsKeyAliasName": {
      "Description": "Stable alias for the SearchLint service-secret KMS key.",
      "Value": {
        "Ref": "SearchLintSecretsKeyAlias"
      }
    },
    "StripeWebhookSecretArn": {
      "Description": "Use this ARN for SEARCHLINT_STRIPE_WEBHOOK_SECRET ECS container secrets.",
      "Value": {
        "Ref": "StripeWebhookSecret"
      }
    },
    "OtelHeadersSecretArn": {
      "Description": "Use this ARN for OTEL_EXPORTER_OTLP_HEADERS ECS container secrets when OTLP headers are required.",
      "Value": {
        "Ref": "OtelHeadersSecret"
      }
    }
  }
}
